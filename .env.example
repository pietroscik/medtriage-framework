# Database
DATABASE_URL=sqlite:///./medtriage.db

# Redis (queue / cache)
REDIS_URL=redis://localhost:6379/0

# WhatsApp API
VERIFY_TOKEN=IL_TUO_VERIFY_TOKEN_SEGRETO
META_ACCESS_TOKEN=IL_TUO_TOKEN_DI_ACCESSO_META
META_PHONE_NUMBER_ID=L_ID_DEL_TUO_NUMERO_DI_TELEFONO


# WhatsApp Meta API
META_WHATSAPP_API_URL=https://graph.facebook.com/v17.0/YOUR_PHONE_ID/messages
META_WHATSAPP_TOKEN=your_meta_whatsapp_token

# Notifiche Email per il medico
MEDICO_EMAIL=email.del.medico@esempio.com
EMAIL_PASSWORD=la_tua_password_per_app_gmail
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=email.del.medico@esempio.com

# Telegram notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Encryption (Fernet key) — generate a real key and put here in .env (do NOT commit)
FERNET_KEY=your_base64_fernet_key

# Backup
BACKUP_DIR=./backups

# Dashboard
DASHBOARD_PASSWORD=una_password_robusta_per_la_dashboard

# Optional
LOG_LEVEL=INFO